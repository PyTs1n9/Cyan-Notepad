# Public Supabase client configuration. Never put the service_role key here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
VITE_COLLAB_URL=ws://127.0.0.1:1234
# Optional when a reverse proxy exposes /health on a different public URL.
# VITE_COLLAB_HEALTH_URL=https://collab.example.com/health
