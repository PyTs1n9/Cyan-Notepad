{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "tile",
  "description": "Capability for tile (sticky note) windows",
  "windows": ["tile-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:event:default",
    "core:event:allow-listen",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$RESOURCE/**" }
      ]
    }
  ]
}
