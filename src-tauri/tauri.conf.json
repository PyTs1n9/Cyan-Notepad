{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CyanNotepad",
  "version": "0.4.0",
  "identifier": "com.cyan-notepad.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8787",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cyan Notepad",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$EXE/**", "$RESOURCE/**"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["cyan-notepad"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
